exports[`pack3mf 回归（默认路径，不传新选项） color assembleAsOne：组合体结构稳定（UUID 归一）: color-root-model 1`] = `
"<?xml version="1.0" encoding="UTF-8"?>
<model unit="millimeter" xml:lang="en-US" xmlns="http://schemas.microsoft.com/3dmanufacturing/core/2015/02" xmlns:BambuStudio="http://schemas.bambulab.com/package/2021" xmlns:p="http://schemas.microsoft.com/3dmanufacturing/production/2015/06" requiredextensions="p">
 <metadata name="Application">BambuStudio-01.10.01.50</metadata>
 <metadata name="BambuStudio:3mfVersion">1</metadata>
 <metadata name="CopyRight">[]</metadata>
 <metadata name="Copyright">[]</metadata>
 <metadata name="CreationDate">2025-01-24</metadata>
 <metadata name="Description">&amp;lt;p&amp;gt;&amp;amp;nbsp;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;&amp;amp;nbsp;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;&amp;lt;span style=&amp;#34;background-color: rgb(36,36,36); color: rgb(214,214,214); font-size: 16px&amp;#34;&amp;gt;生成高分辨率，色阶过渡平滑的3D打印负片（黑白only）[单色打印，无需ams]&amp;lt;/span&amp;gt;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;&amp;amp;nbsp;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;本项目是对旧项目的全新升级&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;&amp;lt;a target=&amp;#34;_blank&amp;#34; rel=&amp;#34;noopener noreferrer ugc&amp;#34; href=&amp;#34;https://makerworld.com.cn/zh/models/194195-da-yin-ji-jiu-gai-yong-lai-da-zhao-pian-cong-zhao#profileId-120871&amp;#34;&amp;gt;https://makerworld.com.cn/zh/models/194195-da-yin-ji-jiu-gai-yong-lai-da-zhao-pian-cong-zhao#profileId-120871&amp;lt;/a&amp;gt;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;&amp;amp;nbsp;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;不再需要下载任何第三方软件，完全在浏览器内，完全本地的预览&amp;amp;amp;生成&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;&amp;amp;nbsp;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;浏览器打开下列任意地址&amp;lt;/p&amp;gt;&amp;lt;ul style=&amp;#34;list-style-type: disc&amp;#34;&amp;gt;&amp;lt;li&amp;gt;&amp;lt;a target=&amp;#34;_blank&amp;#34; rel=&amp;#34;noopener noreferrer ugc&amp;#34; href=&amp;#34;https://vivapercuore.ddns.net:11443/#/photo2relief&amp;#34;&amp;gt;https://vivapercuore.ddns.net:11443/#/photo2relief&amp;lt;/a&amp;gt;&amp;lt;/li&amp;gt;&amp;lt;li&amp;gt;&amp;lt;a target=&amp;#34;_blank&amp;#34; rel=&amp;#34;noopener noreferrer ugc&amp;#34; href=&amp;#34;http://vivapercuore.ddns.net:11080/#/lac2model&amp;#34;&amp;gt;http://vivapercuore.ddns.net:11080/#/photo2relief&amp;lt;/a&amp;gt;&amp;lt;/li&amp;gt;&amp;lt;/ul&amp;gt;&amp;lt;p&amp;gt;&amp;lt;span style=&amp;#34;background-color: rgb(36,36,36); color: rgb(214,214,214); font-size: 16px&amp;#34;&amp;gt;浏览器可能提示不安全，请放心忽略（因为我没有钱做证书）&amp;lt;/span&amp;gt;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;&amp;lt;span style=&amp;#34;background-color: rgb(36,36,36); color: rgb(214,214,214); font-size: 16px&amp;#34;&amp;gt;完全在本地运行，不会上传任何数据，没有任何限制&amp;lt;/span&amp;gt;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;&amp;amp;nbsp;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;根据提示进行操作即可&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;内置了旧版提供的工艺配置，可以直接进行打印&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;&amp;amp;nbsp;&amp;lt;/p&amp;gt;&amp;lt;figure class=&amp;#34;image&amp;#34;&amp;gt;&amp;lt;img src=&amp;#34;https://makerworld.bblmw.cn/makerworld/model/20260608/2724666231/130bd0ae17c3ba03.png&amp;#34;&amp;gt;&amp;lt;/figure&amp;gt;&amp;lt;p&amp;gt;&amp;amp;nbsp;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;对于一些经常问的问题：&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;Q:  拓竹官方已经提供了这个功能，为什么还要做这个呢&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;A：本项目启动时，官方还没有提供该功能，现有项目也可以作为一个补充和额外的选择&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;Q:  和拓竹官方生成的模型有什么区别&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;A:   个人觉得精细度会更高一些，厚度和灰阶细腻程度更可控，同时完全在本地计算，不会上传任何数据，更有隐私性&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;大家自行选择自己喜欢的项目使用就好&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;&amp;amp;nbsp;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;你可以添加其他相框或者背光灯板等其他配件来使用&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;&amp;amp;nbsp;&amp;lt;/p&amp;gt;&amp;lt;boostme&amp;gt;&amp;lt;boosttitle&amp;gt;为我助力&amp;lt;/boosttitle&amp;gt;&amp;lt;boostcontent&amp;gt;喜欢的话欢迎轻点小手哦&amp;lt;/boostcontent&amp;gt;&amp;lt;/boostme&amp;gt;&amp;lt;p&amp;gt;&amp;amp;nbsp;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;希望对你有用&amp;amp;amp;希望你能喜欢&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;&amp;amp;nbsp;&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;示例照片是我的猫，他叫寿司，他非常可爱！请大家夸夸他！&amp;lt;/p&amp;gt;</metadata>
 <metadata name="DesignModelId">CN8b3427a10c0621</metadata>
 <metadata name="DesignProfileId">152167827</metadata>
 <metadata name="DesignRegion">CN</metadata>
 <metadata name="Designer">vivapercuore</metadata>
 <metadata name="DesignerCover">80580fd11233135f.png</metadata>
 <metadata name="DesignerUserId">2724666231</metadata>
 <metadata name="License">MakerWorld Exclusive License</metadata>
 <metadata name="ModificationDate">2025-01-24</metadata>
 <metadata name="Origin">original</metadata>
 <metadata name="ProfileCover">2024-06-22_cb2f82cc1ae6b.jpg</metadata>
 <metadata name="ProfileDescription">&amp;lt;p&amp;gt;0.08mm 层高&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;0.16mm 首层&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;100%充填&amp;lt;/p&amp;gt;&amp;lt;p&amp;gt;以及其他细微调整&amp;lt;/p&amp;gt;</metadata>
 <metadata name="ProfileTitle">0.4喷头 标准配置 </metadata>
 <metadata name="ProfileUserId">2724666231</metadata>
 <metadata name="ProfileUserName">vivapercuore</metadata>
 <metadata name="Thumbnail_Middle">/Metadata/plate_1.png</metadata>
 <metadata name="Thumbnail_Small">/Metadata/plate_1_small.png</metadata>
 <metadata name="Title">打印机就该用来打照片！  从照片转换为透光浮雕照片 3.0 ！</metadata>

 <resources>
  <object id="3" p:UUID="UUID" type="model">
   <components>
    <component p:path="/3D/Objects/colorparts.model" objectid="1" p:UUID="UUID" transform="1 0 0 0 1 0 0 0 1 0 0 0"/>
    <component p:path="/3D/Objects/colorparts.model" objectid="2" p:UUID="UUID" transform="1 0 0 0 1 0 0 0 1 0 0 0"/>
   </components>
  </object>
 </resources>
 <build p:UUID="UUID">
  <item objectid="3" p:UUID="UUID" transform="1 0 0 0 1 0 0 0 1 128 128 0" printable="1"/>
 </build>
</model>"
`;

